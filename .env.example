# ── Banco de dados ────────────────────────────────────────────────────────────
# Docker (PostgreSQL — padrão):
DATABASE_URL=postgresql://postgres:postgres@db:5432/supermercado

# Instalação local sem Docker (SQLite):
# DATABASE_URL=sqlite:///./supermercado.db

# Credenciais do PostgreSQL (usado pelo docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=supermercado

# ── Portas no host (docker-compose) ────────────────────────────────────────────
# Mude se a porta já estiver em uso por outro container/serviço na máquina.
APP_PORT=8000
DB_PORT=5432

# ── Segurança ─────────────────────────────────────────────────────────────────
SECRET_KEY=troque-esta-chave-por-algo-aleatorio-longo-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Empresa ───────────────────────────────────────────────────────────────────
APP_NAME=SuperMarket Pro
MARKET_NAME=Meu Mercado
MARKET_LOGO_URL=/static/img/logo.svg

# ── PIX (configure também pelo painel Empresa) ────────────────────────────────
# PIX_KEY=sua@chave.pix
# PIX_CITY=MANAUS

# ── NFC-e (SEFAZ-AM) ───────────────────────────────────────────────────────────
# NFCE_AMBIENTE=1 → produção | 2 → homologação (sem valor fiscal)
NFCE_AMBIENTE=2
NFCE_SERIE=001
NFCE_XML_DIR=fiscal/xml
# Caminho do certificado digital A1 (.pfx) e senha — sem isso, fica em modo pendente/simulado
NFCE_CERT_PATH=
NFCE_CERT_PASS=
# CSC (Código de Segurança do Contribuinte) — gerado no portal da SEFAZ-AM, usado no QR Code
NFCE_CSC=
NFCE_CSC_ID=
