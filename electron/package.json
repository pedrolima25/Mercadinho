{
  "name": "mercadinho-pdv",
  "version": "1.0.0",
  "description": "PDV Desktop - Mercadinho",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never"
  },
  "build": {
    "appId": "com.mercadinho.pdv",
    "productName": "Mercadinho PDV",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ]
    },
    "portable": {
      "artifactName": "MercadinhoPDV-portable.exe"
    },
    "extraResources": [
      { "from": "config.json", "to": "config.json" }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
